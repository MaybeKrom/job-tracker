{
    "manifest_version": 3,
    "name": "Job Tracker",
    "version": "1.0",
    "description": "Save LinkedIn jobs to your tracker in one click",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
    "https://*/*",
    "http://*/*"
],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Save this job"
    }
}